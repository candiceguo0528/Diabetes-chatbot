# 1) Helper: fit MixedLM and extract Chatbot - Clinician effect
# -----------------------------
def fit_mixedlm_effect(data: pd.DataFrame, outcome: str):
    """
    MixedLM: outcome ~ C(responder_type, Treatment('Clinician'))
    Random intercepts: Case_id (groups) + rater_id (variance component)
    Returns: beta, ci_low, ci_high, p_value, converged
    """
    d = data[["Case_id", "rater_id", "responder_type", outcome]].dropna().copy()

    # If either group missing, return NA
    if d["responder_type"].nunique() < 2:
        return np.nan, np.nan, np.nan, np.nan, False

    # statsmodels formula: set Clinician as reference
    formula = f"{outcome} ~ C(responder_type, Treatment('Clinician'))"

    md = sm.MixedLM.from_formula(
        formula,
        groups="Case_id",
        vc_formula={"rater": "0 + C(rater_id)"},
        re_formula="1",
        data=d
    )

    with warnings.catch_warnings():
        warnings.simplefilter("ignore")
        m = md.fit(reml=True, method="lbfgs", disp=False, maxiter=500)

    # Parameter name for Chatbot effect:
    # C(responder_type, Treatment('Clinician'))[T.Chatbot]
    term = "C(responder_type, Treatment('Clinician'))[T.Chatbot]"
    if term not in m.params.index:
        return np.nan, np.nan, np.nan, np.nan, bool(m.converged)

    beta = float(m.params[term])
    se = float(m.bse[term])
    ci_low = beta - 1.96 * se
    ci_high = beta + 1.96 * se
    p = float(m.pvalues[term])

    return beta, ci_low, ci_high, p, bool(m.converged)

