          .reindex(["Chatbot", "Clinician"])
    )

    cb_mean, cb_sd, cb_n = desc.loc["Chatbot", ["mean", "std", "count"]]
    cl_mean, cl_sd, cl_n = desc.loc["Clinician", ["mean", "std", "count"]]

    # Mixed model effect: Chatbot - Clinician
    beta, lo, hi, p, conv = fit_mixedlm_effect(df, out)

    rows.append({
        "Outcome": out,
        "Chatbot Mean (SD)": f"{cb_mean:.2f} ({cb_sd:.2f})",
        "Clinician Mean (SD)": f"{cl_mean:.2f} ({cl_sd:.2f})",
        "Mean diff (Chatbot−Clinician)": f"{beta:.3f}" if np.isfinite(beta) else "NA",
        "95% CI": f"{lo:.3f} to {hi:.3f}" if np.isfinite(lo) else "NA",
        "P value": "<0.001" if (np.isfinite(p) and p < 0.001) else (f"{p:.3f}" if np.isfinite(p) else "NA"),
        "Converged": conv,
        "n (Chatbot)": int(cb_n),
        "n (Clinician)": int(cl_n),
    })

table2 = pd.DataFrame(rows)

# Optional: nicer outcome names for manuscript
name_map = {
    "overall_quality": "Overall quality",
    "clinical_accuracy": "Clinical accuracy",
    "guideline_adherence": "Guideline adherence",
    "actionability": "Actionability",
    "personalization": "Personalization",
    "clarity": "Clarity",
    "empathy": "Empathy",
}
table2["Outcome"] = table2["Outcome"].map(lambda x: name_map.get(x, x))

# Reorder rows (Overall first)
order = ["Overall quality", "Clinical accuracy", "Guideline adherence", "Actionability",
         "Personalization", "Clarity", "Empathy"]
table2["Outcome"] = pd.Categorical(table2["Outcome"], categories=order, ordered=True)
table2 = table2.sort_values("Outcome").reset_index(drop=True)

# Show in console
print("\n=== Table 2 (Descriptive + MixedLM) ===")
print(table2[["Outcome", "Chatbot Mean (SD)", "Clinician Mean (SD)",
              "Mean diff (Chatbot−Clinician)", "95% CI", "P value"]].to_string(index=False))

# Save for manuscript
table2.to_csv("Table2_quality_comparison.csv", index=False)

# Optional: LaTeX export (for Overleaf)
latex_cols = ["Outcome", "Chatbot Mean (SD)", "Clinician Mean (SD)",
              "Mean diff (Chatbot−Clinician)", "95% CI", "P value"]
latex = table2[latex_cols].to_latex(index=False, escape=False)
with open("Table2_quality_comparison.tex", "w", encoding="utf-8") as f:
    f.write(latex)

print("\nSaved: Table2_quality_comparison.csv and Table2_quality_comparison.tex")
