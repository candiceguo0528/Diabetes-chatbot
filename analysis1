def fit_icc_mixedlm(data: pd.DataFrame, k: int = 3):
    """Fit MixedLM and return (icc2_1, icc2_k, var_target, var_rater, var_error, converged)."""
    md = sm.MixedLM.from_formula(
        "overall_quality ~ 1",
        groups="target_id",
        vc_formula={"rater": "0 + C(rater_id)"},
        re_formula="1",
        data=data
    )
    m = md.fit(reml=True, method="lbfgs", disp=False)

    var_target = float(m.cov_re.iloc[0, 0])
    var_rater  = float(m.vcomp[0]) if len(m.vcomp) else 0.0
    var_error  = float(m.scale)

    icc2_1 = var_target / (var_target + var_rater + var_error)
    icc2_k = var_target / (var_target + var_rater / k + var_error / k)

    return icc2_1, icc2_k, var_target, var_rater, var_error, bool(m.converged)


def bootstrap_icc_ci(icc_df: pd.DataFrame, k: int = 3, B: int = 1000, seed: int = 2026):
    """
    Cluster bootstrap by target_id to obtain percentile 95% CI for ICC(2,1) and ICC(2,k).
    Returns dict with point estimates + CI + bootstrap distribution summary.
    """
    rng = np.random.default_rng(seed)

    targets = icc_df["target_id"].unique()
    n_targets = len(targets)

    # Point estimate on full data
    icc2_1_hat, icc2_k_hat, vt_hat, vr_hat, ve_hat, conv_hat = fit_icc_mixedlm(icc_df, k=k)

    icc2_1_boot = []
    icc2_k_boot = []
    n_fail = 0

    # Pre-group rows per target for fast resampling
    grouped = {tid: g for tid, g in icc_df.groupby("target_id", sort=False)}

    warnings.filterwarnings("ignore")  # MixedLM often throws convergence warnings in bootstrap

    for _ in tqdm(range(B), desc=f"Bootstrapping ICC (B={B})"):
        sampled_targets = rng.choice(targets, size=n_targets, replace=True)

        # Concatenate sampled clusters; re-label target_id to keep duplicates independent
        # (important: if a target is sampled twice, they must be treated as two clusters)
        boot_parts = []
        for j, tid in enumerate(sampled_targets):
            g = grouped[tid].copy()
            g["target_id"] = g["target_id"].astype(str) + f"__boot{j}"
            boot_parts.append(g)

        boot_df = pd.concat(boot_parts, axis=0, ignore_index=True)

        try:
            icc2_1_b, icc2_k_b, *_ = fit_icc_mixedlm(boot_df, k=k)
            if np.isfinite(icc2_1_b) and np.isfinite(icc2_k_b):
                icc2_1_boot.append(icc2_1_b)
                icc2_k_boot.append(icc2_k_b)
            else:
                n_fail += 1
        except Exception:
            n_fail += 1
            continue

    icc2_1_boot = np.array(icc2_1_boot, dtype=float)
    icc2_k_boot = np.array(icc2_k_boot, dtype=float)

    # Percentile CI
    ci_1 = np.quantile(icc2_1_boot, [0.025, 0.975]) if len(icc2_1_boot) else (np.nan, np.nan)
    ci_k = np.quantile(icc2_k_boot, [0.025, 0.975]) if len(icc2_k_boot) else (np.nan, np.nan)

    return {
        "point": {
            "ICC(2,1)": icc2_1_hat,
            f"ICC(2,{k})": icc2_k_hat,
            "Var_target": vt_hat,
            "Var_rater": vr_hat,
            "Var_error": ve_hat,
            "Converged": conv_hat,
        },
        "bootstrap": {
            "B_requested": B,
            "B_success": int(len(icc2_1_boot)),
            "B_failed": int(n_fail),
            "ICC(2,1)_CI95": tuple(ci_1),
            f"ICC(2,{k})_CI95": tuple(ci_k),
        }
    }


