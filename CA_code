###############################################################################
# OpenAI Multimodal Helpers
###############################################################################

def build_multimodal_user_content(text_prompt: str, image_paths: Optional[List[Path]] = None) -> list:
    content = [{"type": "input_text", "text": text_prompt}]
    image_paths = image_paths or []

    for img_path in image_paths:
        data_url = encode_image_to_data_url(img_path)
        content.append({
            "type": "input_image",
            "image_url": data_url
        })

    return content


def call_glumentor(
    client: OpenAI,
    model_name: str,
    system_prompt: str,
    conversation_history: list,
    user_text_prompt: str,
    image_paths: Optional[List[Path]] = None,
) -> str:
    input_payload = [
        {
            "role": "system",
            "content": [{"type": "input_text", "text": system_prompt}]
        }
    ]

    for turn in conversation_history:
        if turn["role"] == "user":
            input_payload.append({
                "role": "user",
                "content": [{"type": "input_text", "text": turn["content"]}]
            })
        elif turn["role"] == "assistant":
            input_payload.append({
                "role": "assistant",
                "content": [{"type": "output_text", "text": turn["content"]}]
            })

    input_payload.append({
        "role": "user",
        "content": build_multimodal_user_content(user_text_prompt, image_paths=image_paths)
    })

    response = client.responses.create(
        model=model_name,
        input=input_payload
    )

    return response.output_text.strip()


###############################################################################
# Chatbot Interaction
###############################################################################

def run_glu_mentor_with_memory(
    summary_text: str,
    tir: float,
    patient_info: str,
    api_key: str,
    vectorstore=None,
    initial_image_paths: Optional[List[Path]] = None,
    model_name: str = "gpt-5.1",
):
    client = OpenAI(api_key=api_key)
    history: list = []

    initial_rag_context = "No additional guideline context retrieved."
    initial_prompt = INITIAL_USER_PROMPT.format(
        summary=summary_text,
        tir=tir,
        patient_info=patient_info,
        rag_context=initial_rag_context
    )

    first_answer = call_glumentor(
        client=client,
        model_name=model_name,
        system_prompt=SYSTEM_PROMPT,
        conversation_history=history,
        user_text_prompt=initial_prompt,
        image_paths=initial_image_paths,
    )

    print("\nGluMentor:\n")
    print(first_answer)

    history.append({"role": "user", "content": initial_prompt})
    history.append({"role": "assistant", "content": first_answer})

    while True:
        user_input = input("\nYou: ").strip()
        if user_input.lower() in {"exit", "quit"}:
            print("GluMentor: Goodbye!")
            break

        image_input = input("Optional image path(s), separated by commas, or press Enter to skip: ").strip()
        turn_images = []
        if image_input:
            raw_paths = [x.strip() for x in image_input.split(",") if x.strip()]
            turn_images = collect_image_paths(raw_paths)

        rag_context = rag_retrieve(user_input, vectorstore) if needs_rag(user_input) else "No guideline reference retrieved."

        followup_prompt = FOLLOWUP_USER_PROMPT.format(
            summary=summary_text,
            patient_info=patient_info,
            user_input=user_input,
            rag_context=rag_context
        )

        answer = call_glumentor(
            client=client,
            model_name=model_name,
            system_prompt=SYSTEM_PROMPT,
            conversation_history=history,
            user_text_prompt=followup_prompt,
            image_paths=turn_images,
        )

        print("\nGluMentor:\n")
        print(answer)

        history.append({"role": "user", "content": followup_prompt})
        history.append({"role": "assistant", "content": answer})


