###############################################################################
# CGM Analysis from Excel
###############################################################################

def analyze_cgm_from_excel(file_path: Union[str, Path], tir_range: tuple = (70, 180)) -> dict:
    df = pd.read_excel(file_path)

    time_col = next(
        (col for col in df.columns if "date" in col.lower() or "time" in col.lower() or "时间" in col.lower()),
        None
    )
    if not time_col:
        raise ValueError("No valid time column found.")

    df[time_col] = pd.to_datetime(df[time_col], errors="coerce")
    df = df.dropna(subset=[time_col])

    glucose_col = next(
        (col for col in df.columns if "cgm" in col.lower() and "mg" in col.lower()),
        None
    )
    if not glucose_col:
        raise ValueError("No CGM column found.")

    df = df.dropna(subset=[glucose_col]).copy()
    df = df.sort_values(time_col)

    values = pd.to_numeric(df[glucose_col], errors="coerce").dropna()
    if values.empty:
        raise ValueError("No valid glucose values found.")

    n = len(values)
    start = df[time_col].min().floor("D")
    end = df[time_col].max().floor("D")
    days = (end - start).days + 1

    intervals = df[time_col].diff().dropna().dt.total_seconds() / 60
    median_interval = intervals.median() if not intervals.empty else 5
    expected_per_day = int(1440 / median_interval) if median_interval and median_interval > 0 else 288
    completeness = n / (days * expected_per_day) * 100 if days > 0 else 0

    low, high = tir_range
    tir = (values.between(low, high).mean()) * 100
    tar = (values > high).mean() * 100
    tar250 = (values > 250).mean() * 100
    tbr = (values < low).mean() * 100
    tbr54 = (values < 54).mean() * 100

    mean_glucose = values.mean()
    std_glucose = values.std()
    cv = std_glucose / mean_glucose * 100 if mean_glucose else 0
    gmi = 3.31 + 0.02392 * mean_glucose

    return {
        "monitoring_days": days,
        "total_readings": int(n),
        "wear_completeness": round(completeness, 1),
        "mean_glucose": round(mean_glucose, 1),
        "gmi": round(gmi, 2),
        "sd": round(std_glucose, 1),
        "cv": round(cv, 1),
        "tir": round(tir, 1),
        "above_180": round(tar, 1),
        "above_250": round(tar250, 1),
        "below_70": round(tbr, 1),
        "below_54": round(tbr54, 1),
    }


def format_cgm_summary_table(stats: dict) -> str:
    return f"""CGM Analysis Report
-------------------
Monitoring days              : {stats['monitoring_days']}
Wear time completeness       : {stats['wear_completeness']}% (target ≥70%)
Total readings               : {stats['total_readings']}

Mean glucose                 : {stats['mean_glucose']} mg/dL
GMI (estimated HbA1c)        : {stats['gmi']}%
Standard deviation (SD)      : {stats['sd']} mg/dL
Coefficient of variation (CV): {stats['cv']}% (target <36%)

Time in Range 70–180         : {stats['tir']}% (target ≥70%)
Time Below <70 mg/dL         : {stats['below_70']}% (target <4%)
  └─ Severe <54 mg/dL        : {stats['below_54']}% (target <1%)
Time Above >180 mg/dL        : {stats['above_180']}% (target <25%)
  └─ Very high >250 mg/dL    : {stats['above_250']}% (target <5%)"""


###############################################################################
# Patient Info
###############################################################################

def load_patient_info(path: Union[str, Path]) -> str:
    path = Path(path)
    if not path.exists():
        raise FileNotFoundError(f"File not found: {path}")

    if path.suffix.lower() == ".csv":
        df = pd.read_csv(path)
        data = df.to_dict(orient="records")[0]
        return "\n".join([f"{k.replace('_', ' ').capitalize()}: {v}" for k, v in data.items()])

    if path.suffix.lower() == ".json":
        with open(path, "r", encoding="utf-8", errors="ignore") as f:
            data = json.load(f)
        return "\n".join([f"{k.replace('_', ' ').capitalize()}: {v}" for k, v in data.items()])

    if path.suffix.lower() == ".docx":
        from docx import Document
        doc = Document(path)
        lines = [para.text.strip() for para in doc.paragraphs if para.text.strip()]
        return "\n".join(lines)

    if path.suffix.lower() == ".txt":
        return path.read_text(encoding="utf-8", errors="ignore")

    raise ValueError("Unsupported patient profile format. Use .csv, .json, .docx, or .txt")


###############################################################################
# Image Helpers
###############################################################################

def encode_image_to_data_url(image_path: Union[str, Path]) -> str:
    image_path = Path(image_path)
    if not image_path.exists():
        raise FileNotFoundError(f"Image not found: {image_path}")

    mime_type, _ = mimetypes.guess_type(str(image_path))
    if mime_type is None:
        mime_type = "image/png"

    with open(image_path, "rb") as f:
        image_bytes = f.read()

    b64 = base64.b64encode(image_bytes).decode("utf-8")
    return f"data:{mime_type};base64,{b64}"


def collect_image_paths(
    image_inputs: Optional[Union[str, Path, List[Union[str, Path]]]]
) -> List[Path]:
    if image_inputs is None:
        return []

    if isinstance(image_inputs, (str, Path)):
        image_inputs = [image_inputs]

    valid_suffixes = {".png", ".jpg", ".jpeg", ".webp"}
    image_paths: List[Path] = []

    for item in image_inputs:
        p = Path(item)
        if p.is_dir():
            for child in sorted(p.iterdir()):
                if child.suffix.lower() in valid_suffixes:
                    image_paths.append(child)
        elif p.is_file() and p.suffix.lower() in valid_suffixes:
            image_paths.append(p)
        else:
            print(f"Skipping invalid image path: {p}")

    return image_paths


###############################################################################
# Vector Store for RAG
###############################################################################

def build_vector_store_from_pdf(pdf_path: Union[str, Path], api_key: str):
    pdf_path = Path(pdf_path)
    if not pdf_path.exists():
        return None

    loader = PyPDFLoader(str(pdf_path))
    docs = loader.load()

    splitter = RecursiveCharacterTextSplitter(
        chunk_size=800,
        chunk_overlap=150
    )
    chunks = splitter.split_documents(docs)

    embeddings = OpenAIEmbeddings(api_key=api_key)
    vectorstore = FAISS.from_documents(chunks, embeddings)
    return vectorstore


def rag_retrieve(query: str, vectorstore, k: int = 3) -> str:
    if vectorstore is None:
        return ""

    docs = vectorstore.similarity_search(query, k=k)
    if not docs:
        return ""

    output = []
    for i, doc in enumerate(docs, start=1):
        page = doc.metadata.get("page", "unknown")
        output.append(f"[Reference {i} | page {page}]\n{doc.page_content}")

    return "\n\n".join(output)


def needs_rag(text: str) -> bool:
    keywords = [
        "what", "how", "why", "tir", "a1c", "gmi", "guideline",
        "explain", "recommendation", "meal", "diet", "exercise",
        "insulin", "medication", "low", "high", "hypo", "hyper"
    ]
    text_lower = text.lower()
    return any(k in text_lower for k in keywords)


